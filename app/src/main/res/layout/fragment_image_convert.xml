<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal">

        <!-- ── File pick card ─────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardPickFile"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            app:cardCornerRadius="16dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="?attr/colorPrimary"
            app:cardElevation="0dp"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">

                <!-- File thumbnail (hidden until file picked) -->
                <ImageView
                    android:id="@+id/imgPreview"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:scaleType="centerCrop"
                    android:visibility="gone" />

                <!-- Placeholder icon (visible until file picked) -->
                <ImageView
                    android:id="@+id/iconPlaceholder"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_add_photo"
                    app:tint="?attr/colorPrimary" />

                <TextView
                    android:id="@+id/tvPickHint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/tap_to_pick"
                    android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                    android:textColor="?attr/colorOnSurfaceVariant" />

                <TextView
                    android:id="@+id/tvFileName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                    android:textColor="?attr/colorPrimary"
                    android:visibility="gone"
                    android:ellipsize="middle"
                    android:singleLine="true" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Format selector ───────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="10dp"
            android:text="@string/output_format"
            android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/formatChipGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipJpg"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="JPG"
                android:checked="true" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipPng"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PNG" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipWebp"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WebP" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipBmp"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BMP" />

        </com.google.android.material.chip.ChipGroup>

        <!-- ── Convert button ────────────────────────────── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConvert"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:text="@string/convert"
            android:textSize="16sp"
            app:cornerRadius="12dp"
            android:enabled="false" />

        <!-- ── Progress ──────────────────────────────────── -->
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progressBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            app:trackCornerRadius="4dp" />

    </LinearLayout>
</ScrollView>
